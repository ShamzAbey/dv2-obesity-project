{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Overview and detail line chart for selected ABS beverage consumption trends. The lower brush filters the upper detail chart.",
  "title": "Selected beverage consumption, overview and detail",
  "data": {"url": "../data/food_consumption.csv"},
  "vconcat": [
    {
      "width": "container",
      "height": 300,
      "transform": [{"filter": {"param": "yearBrush"}}],
      "mark": {"type": "line", "point": {"filled": true, "size": 55}, "strokeWidth": 3},
      "encoding": {
        "x": {
          "field": "year_start",
          "type": "quantitative",
          "title": "Financial year beginning",
          "axis": {"format": "d", "tickMinStep": 1}
        },
        "y": {
          "field": "ml_per_capita_per_day",
          "type": "quantitative",
          "title": "mL per capita per day"
        },
        "color": {
          "field": "category",
          "type": "nominal",
          "title": "Food/beverage category",
          "scale": {"range": ["#0f6f73", "#b37a16", "#d9a441", "#8056a3", "#c94f2d", "#5b8f4d", "#8a6f3f"]}
        },
        "tooltip": [
          {"field": "year", "type": "ordinal", "title": "Financial year"},
          {"field": "category", "type": "nominal", "title": "Category"},
          {"field": "ml_per_capita_per_day", "type": "quantitative", "title": "mL per capita per day", "format": ".1f"}
        ]
      }
    },
    {
      "width": "container",
      "height": 86,
      "transform": [
        {
          "aggregate": [
            {
              "op": "sum",
              "field": "ml_per_capita_per_day",
              "as": "total_ml_per_capita_per_day"
            }
          ],
          "groupby": ["year", "year_start"]
        }
      ],
      "params": [
        {
          "name": "yearBrush",
          "select": {"type": "interval", "encodings": ["x"]}
        }
      ],
      "mark": {"type": "line", "strokeWidth": 2},
      "encoding": {
        "x": {
          "field": "year_start",
          "type": "quantitative",
          "title": "Brush to zoom/filter",
          "axis": {"format": "d", "tickMinStep": 1}
        },
        "y": {
          "field": "total_ml_per_capita_per_day",
          "type": "quantitative",
          "title": "Total",
          "axis": {"labelFontSize": 10}
        },
        "color": {"value": "#2f6f9f"},
        "tooltip": [
          {"field": "year", "type": "ordinal", "title": "Financial year"},
          {"field": "total_ml_per_capita_per_day", "type": "quantitative", "title": "Total mL per capita per day", "format": ".1f"}
        ]
      }
    }
  ],
  "resolve": {"scale": {"x": "shared", "color": "shared"}},
  "config": {
    "view": {"stroke": "#d9dde2"},
    "axis": {"labelFontSize": 12, "titleFontSize": 12, "gridColor": "#e6e8eb"},
    "legend": {"labelFontSize": 11, "titleFontSize": 12, "orient": "bottom"}
  }
}
