{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Overview and detail line chart for selected ABS beverage consumption trends. The lower brush filters the upper detail chart.",
  "title": "Selected beverage consumption, overview and detail",
  "data": {"url": "../data/food_consumption.csv"},
  "vconcat": [
    {
      "width": "container",
      "height": 300,
      "transform": [{"filter": {"param": "yearBrush"}}],
      "layer": [
        {
          "mark": {"type": "line", "point": {"filled": true, "size": 55}, "strokeWidth": 3},
          "encoding": {
            "x": {"field": "year_start", "type": "quantitative", "title": "Financial year beginning", "axis": {"format": "d", "tickMinStep": 1}},
            "y": {"field": "ml_per_capita_per_day", "type": "quantitative", "title": "mL per capita per day"},
            "color": {"field": "category", "type": "nominal", "title": "Food/beverage category", "scale": {"range": ["#4b2a78", "#6f4bb2", "#8b4fd3", "#a66bd8", "#c29be6", "#5e63c7", "#8d89dd"]}},
            "tooltip": [
              {"field": "year", "type": "ordinal", "title": "Financial year"},
              {"field": "category", "type": "nominal", "title": "Category"},
              {"field": "ml_per_capita_per_day", "type": "quantitative", "title": "mL per capita per day", "format": ".1f"}
            ]
          }
        },
        {
          "transform": [{"filter": "datum.category == 'Soft drinks'"}],
          "mark": {"type": "line", "stroke": "#261f33", "strokeWidth": 4, "opacity": 0.9},
          "encoding": {
            "x": {"field": "year_start", "type": "quantitative"},
            "y": {"field": "ml_per_capita_per_day", "type": "quantitative"}
          }
        },
        {
          "transform": [{"filter": "datum.category == 'Soft drinks' && datum.year == '2023-24'"}],
          "mark": {"type": "text", "align": "left", "dx": 8, "dy": -8, "fontWeight": "bold", "color": "#261f33"},
          "encoding": {
            "x": {"field": "year_start", "type": "quantitative"},
            "y": {"field": "ml_per_capita_per_day", "type": "quantitative"},
            "text": {"value": "Soft drinks"}
          }
        }
      ]
    },
    {
      "width": "container",
      "height": 86,
      "transform": [
        {
          "aggregate": [
            {
              "op": "sum",
              "field": "ml_per_capita_per_day",
              "as": "total_ml_per_capita_per_day"
            }
          ],
          "groupby": ["year", "year_start"]
        }
      ],
      "params": [
        {
          "name": "yearBrush",
          "select": {"type": "interval", "encodings": ["x"]}
        }
      ],
      "mark": {"type": "line", "strokeWidth": 2},
      "encoding": {
        "x": {
          "field": "year_start",
          "type": "quantitative",
          "title": "Brush to zoom/filter",
          "axis": {"format": "d", "tickMinStep": 1}
        },
        "y": {
          "field": "total_ml_per_capita_per_day",
          "type": "quantitative",
          "title": "Total",
          "axis": {"labelFontSize": 10}
        },
        "color": {"value": "#6f4bb2"},
        "tooltip": [
          {"field": "year", "type": "ordinal", "title": "Financial year"},
          {"field": "total_ml_per_capita_per_day", "type": "quantitative", "title": "Total mL per capita per day", "format": ".1f"}
        ]
      }
    }
  ],
  "resolve": {"scale": {"x": "shared", "color": "shared"}},
  "config": {
    "view": {"stroke": "#ddd3ec"},
    "axis": {"labelFontSize": 12, "titleFontSize": 12, "gridColor": "#eee8f7"},
    "legend": {"labelFontSize": 11, "titleFontSize": 12, "orient": "bottom"}
  }
}
