{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Physical activity guideline achievement versus adult obesity rates by state and territory, with point size representing ABS population at 30 June 2022.",
  "title": "Physical activity and obesity by state and territory",
  "width": "container",
  "height": 340,
  "data": {"url": "../data/physical_activity.csv"},
  "layer": [
    {
      "mark": {"type": "circle", "filled": true, "opacity": 0.84},
      "encoding": {
        "x": {
          "field": "met_guidelines_percent",
          "type": "quantitative",
          "title": "People aged 15+ meeting physical activity guidelines (%)",
          "scale": {"domain": [19, 26]}
        },
        "y": {
          "field": "obesity_percent",
          "type": "quantitative",
          "title": "Adults obese (%)",
          "scale": {"domain": [28, 39]}
        },
        "size": {
          "field": "population_thousands",
          "type": "quantitative",
          "title": "Population ('000)",
          "scale": {"range": [120, 1600]}
        },
        "color": {
          "field": "state",
          "type": "nominal",
          "title": "State/territory",
          "scale": {"range": ["#0f6f73", "#2f6f9f", "#b37a16", "#8056a3", "#c94f2d", "#5b8f4d", "#8a6f3f", "#5f6f73"]}
        },
        "tooltip": [
          {"field": "state_full", "type": "nominal", "title": "State/territory"},
          {"field": "met_guidelines_percent", "type": "quantitative", "title": "Met guidelines (%)", "format": ".1f"},
          {"field": "obesity_percent", "type": "quantitative", "title": "Obese (%)", "format": ".1f"},
          {"field": "population_thousands", "type": "quantitative", "title": "Population ('000)", "format": ",.1f"}
        ]
      }
    },
    {
      "transform": [{"filter": "datum.state == 'Tas' || datum.state == 'ACT'"}],
      "mark": {"type": "text", "align": "left", "dx": 10, "dy": -8, "fontWeight": "bold", "color": "#263238"},
      "encoding": {
        "x": {"field": "met_guidelines_percent", "type": "quantitative"},
        "y": {"field": "obesity_percent", "type": "quantitative"},
        "text": {"field": "state", "type": "nominal"}
      }
    }
  ],
  "config": {
    "view": {"stroke": null},
    "axis": {"labelFontSize": 12, "titleFontSize": 12, "gridColor": "#e6e8eb"},
    "legend": {"labelFontSize": 11, "titleFontSize": 12}
  }
}
