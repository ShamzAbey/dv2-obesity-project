{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Adult overweight and obesity age/sex trend values from ABS NHS 2022 Table 8.3, as cited by AIHW 2024.",
  "width": "container",
  "height": 320,
  "data": {"url": "../data/obesity_gender.csv"},
  "mark": {"type": "line", "point": {"filled": true, "size": 70}, "strokeWidth": 3},
  "encoding": {
    "x": {
      "field": "age_group",
      "type": "ordinal",
      "title": "Age group",
      "sort": ["18-24", "25-34", "35-44", "45-54", "55-64", "65+"]
    },
    "y": {
      "field": "overweight_obese_percent",
      "type": "quantitative",
      "title": "Adults overweight or obese (%)",
      "scale": {"domain": [35, 85]}
    },
    "color": {
      "field": "sex",
      "type": "nominal",
      "title": "Sex",
      "scale": {"range": ["#1f77b4", "#d95f02"]}
    },
    "tooltip": [
      {"field": "age_group", "type": "ordinal", "title": "Age group"},
      {"field": "sex", "type": "nominal", "title": "Sex"},
      {"field": "overweight_obese_percent", "type": "quantitative", "title": "Overweight/obese (%)", "format": ".1f"},
      {"field": "obesity_percent", "type": "quantitative", "title": "Obese (%)", "format": ".1f"}
    ]
  },
  "config": {
    "view": {"stroke": null},
    "axis": {"labelFontSize": 12, "titleFontSize": 12, "gridColor": "#e6e8eb"},
    "legend": {"labelFontSize": 12, "titleFontSize": 12}
  }
}
