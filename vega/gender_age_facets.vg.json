{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Small multiples comparing adult obesity by sex across age groups using ABS NHS 2022 BMI proportions.",
  "title": "Adult obesity by sex and age group, 2022",
  "data": {"url": "../data/obesity_gender.csv"},
  "facet": {
    "column": {
      "field": "sex",
      "type": "nominal",
      "title": null,
      "header": {"labelFontSize": 14, "labelFontWeight": "bold"}
    }
  },
  "spec": {
    "width": 300,
    "height": 260,
    "mark": {"type": "bar", "cornerRadiusTopLeft": 3, "cornerRadiusTopRight": 3},
    "encoding": {
      "x": {
        "field": "age_group",
        "type": "ordinal",
        "title": "Age group",
        "sort": ["18-24", "25-34", "35-44", "45-54", "55-64", "65+"],
        "axis": {"labelAngle": 0}
      },
      "y": {
        "field": "obesity_percent",
        "type": "quantitative",
        "title": "Adults obese (%)",
        "scale": {"domain": [0, 45]}
      },
      "color": {
        "field": "sex",
        "type": "nominal",
        "legend": null,
        "scale": {"range": ["#6f4bb2", "#c29be6"]}
      },
      "tooltip": [
        {"field": "sex", "type": "nominal", "title": "Sex"},
        {"field": "age_group", "type": "ordinal", "title": "Age group"},
        {"field": "obesity_percent", "type": "quantitative", "title": "Obese (%)", "format": ".1f"},
        {"field": "overweight_obese_percent", "type": "quantitative", "title": "Overweight/obese (%)", "format": ".1f"}
      ]
    }
  },
  "resolve": {"scale": {"y": "shared"}},
  "config": {
    "view": {"stroke": null},
    "axis": {"labelFontSize": 11, "titleFontSize": 12, "gridColor": "#eee8f7"}
  }
}
