{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Tile heatmap of physical activity guideline achievement by state and territory.",
  "title": "Physical activity guideline achievement tile heatmap",
  "width": "container",
  "height": 260,
  "data": {"url": "../data/physical_activity.csv"},
  "transform": [{"calculate": "'Met guidelines'", "as": "metric"}],
  "mark": {"type": "rect", "cornerRadius": 6},
  "encoding": {
    "x": {"field": "state", "type": "ordinal", "title": "State/territory", "axis": {"labelAngle": 0}},
    "y": {"field": "metric", "type": "nominal", "title": null},
    "color": {
      "field": "met_guidelines_percent",
      "type": "quantitative",
      "title": "Met guidelines (%)",
      "scale": {"range": ["#ede2f8", "#8d89dd", "#5e63c7"], "domain": [20, 23, 26]}
    },
    "tooltip": [
      {"field": "state_full", "type": "nominal", "title": "State/territory"},
      {"field": "met_guidelines_percent", "type": "quantitative", "title": "Met guidelines (%)", "format": ".1f"},
      {"field": "obesity_percent", "type": "quantitative", "title": "Obese (%)", "format": ".1f"}
    ]
  },
  "config": {
    "view": {"stroke": null},
    "axis": {"labelFontSize": 12, "titleFontSize": 12, "gridColor": "#eee8f7"}
  }
}
