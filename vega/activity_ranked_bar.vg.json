{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Lifestyle risk index bullet chart combining adult obesity and low physical activity by state and territory.",
  "title": "Lifestyle risk index: obesity plus low activity",
  "width": "container",
  "height": 320,
  "layer": [
    {
      "data": {"url": "../data/lifestyle_risk_bands.csv"},
      "mark": {"type": "rect", "opacity": 0.28},
      "encoding": {
        "x": {
          "field": "x0",
          "type": "quantitative",
          "scale": {"domain": [52, 58], "nice": false},
          "title": "Lifestyle risk index"
        },
        "x2": {"field": "x1"},
        "y": {"value": 0},
        "y2": {"value": 320},
        "color": {
          "field": "band",
          "type": "nominal",
          "legend": {"title": "Risk band", "orient": "bottom"},
          "scale": {"range": ["#eee5f9", "#d4baf2", "#a879dc"]}
        },
        "tooltip": [
          {"field": "band", "type": "nominal", "title": "Risk band"},
          {"field": "x0", "type": "quantitative", "title": "From", "format": ".0f"},
          {"field": "x1", "type": "quantitative", "title": "To", "format": ".0f"}
        ]
      }
    },
    {
      "data": {"url": "../data/lifestyle_risk_index.csv"},
      "transform": [{"calculate": "52", "as": "baseline"}],
      "mark": {"type": "rule", "stroke": "#b58be7", "strokeWidth": 6, "opacity": 0.9},
      "encoding": {
        "y": {
          "field": "state",
          "type": "ordinal",
          "sort": {"field": "risk_index", "order": "descending"},
          "title": "State/territory"
        },
        "x": {"field": "baseline", "type": "quantitative"},
        "x2": {"field": "risk_index", "type": "quantitative"}
      }
    },
    {
      "data": {"url": "../data/lifestyle_risk_index.csv"},
      "mark": {"type": "circle", "filled": true, "opacity": 0.95, "stroke": "white", "strokeWidth": 1.5},
      "encoding": {
        "y": {
          "field": "state",
          "type": "ordinal",
          "sort": {"field": "risk_index", "order": "descending"}
        },
        "x": {"field": "risk_index", "type": "quantitative"},
        "size": {
          "field": "population_thousands",
          "type": "quantitative",
          "title": "Population ('000)",
          "scale": {"range": [120, 900]}
        },
        "color": {
          "field": "risk_index",
          "type": "quantitative",
          "title": "Risk index",
          "scale": {"range": ["#d8c5f4", "#8b4fd3", "#4b2a78"], "domain": [53, 55, 57]}
        },
        "tooltip": [
          {"field": "state_full", "type": "nominal", "title": "State/territory"},
          {"field": "risk_index", "type": "quantitative", "title": "Risk index", "format": ".1f"},
          {"field": "obesity_percent", "type": "quantitative", "title": "Adults obese (%)", "format": ".1f"},
          {"field": "inactive_percent", "type": "quantitative", "title": "Not meeting activity guidelines (%)", "format": ".1f"},
          {"field": "population_thousands", "type": "quantitative", "title": "Population ('000)", "format": ",.1f"}
        ]
      }
    },
    {
      "data": {"url": "../data/lifestyle_risk_index.csv"},
      "mark": {"type": "rule", "stroke": "#4b2a78", "strokeDash": [5, 4], "strokeWidth": 2},
      "encoding": {
        "x": {"aggregate": "mean", "field": "risk_index", "type": "quantitative"}
      }
    },
    {
      "data": {"url": "../data/lifestyle_risk_index.csv"},
      "mark": {"type": "text", "align": "left", "dx": 10, "fontSize": 12, "fontWeight": "bold", "color": "#261f33"},
      "encoding": {
        "y": {
          "field": "state",
          "type": "ordinal",
          "sort": {"field": "risk_index", "order": "descending"}
        },
        "x": {"field": "risk_index", "type": "quantitative"},
        "text": {"field": "risk_index", "type": "quantitative", "format": ".1f"}
      }
    },
    {
      "data": {"url": "../data/lifestyle_risk_index.csv"},
      "mark": {"type": "text", "align": "left", "dx": 6, "dy": -142, "fontSize": 11, "fontStyle": "italic", "color": "#4b2a78"},
      "encoding": {
        "x": {"aggregate": "mean", "field": "risk_index", "type": "quantitative"},
        "text": {"value": "Mean"}
      }
    }
  ],
  "resolve": {"scale": {"color": "independent"}},
  "config": {
    "view": {"stroke": null},
    "axis": {"labelFontSize": 12, "titleFontSize": 12, "gridColor": "#eee8f7"},
    "legend": {"labelFontSize": 11, "titleFontSize": 12}
  }
}
