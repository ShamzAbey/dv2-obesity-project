{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Bubble matrix comparing physical activity guideline achievement and adult obesity by state and territory. Colour shows rate and bubble size shows population.",
  "title": "Physical activity and obesity bubble matrix",
  "width": "container",
  "height": 250,
  "data": {"url": "../data/physical_activity.csv"},
  "transform": [
    {
      "fold": ["met_guidelines_percent", "obesity_percent"],
      "as": ["metric", "value"]
    },
    {
      "calculate": "datum.metric == 'met_guidelines_percent' ? 'Met activity guidelines' : 'Adults obese'",
      "as": "metric_label"
    }
  ],
  "params": [
    {
      "name": "hoverTile",
      "select": {"type": "point", "fields": ["state", "metric_label"], "on": "mouseover", "clear": "mouseout"}
    }
  ],
  "layer": [
    {
      "mark": {"type": "circle", "filled": true, "opacity": 0.86},
      "encoding": {
        "x": {"field": "state", "type": "ordinal", "title": "State/territory", "axis": {"labelAngle": 0}},
        "y": {
          "field": "metric_label",
          "type": "nominal",
          "title": null,
          "sort": ["Met activity guidelines", "Adults obese"]
        },
        "color": {
          "field": "value",
          "type": "quantitative",
          "title": "Rate (%)",
          "scale": {"range": ["#ede2f8", "#8d89dd", "#4b2a78"], "domain": [20, 28, 38]}
        },
        "size": {
          "field": "population_thousands",
          "type": "quantitative",
          "title": "Population ('000)",
          "scale": {"range": [700, 4200]}
        },
        "stroke": {
          "condition": {"param": "hoverTile", "value": "#261f33"},
          "value": "#ffffff"
        },
        "strokeWidth": {
          "condition": {"param": "hoverTile", "value": 2},
          "value": 0.7
        },
        "tooltip": [
          {"field": "state_full", "type": "nominal", "title": "State/territory"},
          {"field": "metric_label", "type": "nominal", "title": "Indicator"},
          {"field": "value", "type": "quantitative", "title": "Rate (%)", "format": ".1f"},
          {"field": "population_thousands", "type": "quantitative", "title": "Population ('000)", "format": ",.1f"}
        ]
      }
    },
    {
      "mark": {"type": "text", "fontSize": 11, "fontWeight": "bold", "color": "#261f33"},
      "encoding": {
        "x": {"field": "state", "type": "ordinal"},
        "y": {
          "field": "metric_label",
          "type": "nominal",
          "sort": ["Met activity guidelines", "Adults obese"]
        },
        "text": {"field": "value", "type": "quantitative", "format": ".1f"}
      }
    },
    {
      "data": {
        "values": [
          {"state": "Tas", "metric_label": "Adults obese", "label": "Highest obesity"}
        ]
      },
      "mark": {"type": "text", "dy": 36, "fontSize": 10, "fontStyle": "italic", "fontWeight": "bold", "color": "#4b2a78"},
      "encoding": {
        "x": {"field": "state", "type": "ordinal"},
        "y": {
          "field": "metric_label",
          "type": "nominal",
          "sort": ["Met activity guidelines", "Adults obese"]
        },
        "text": {"field": "label", "type": "nominal"}
      }
    }
  ],
  "config": {
    "view": {"stroke": null},
    "axis": {"labelFontSize": 12, "titleFontSize": 12, "gridColor": "#eee8f7"}
  }
}
